# ─────────────────────────────────────────────────────────────────────────────
# Lyra — root .env for docker compose
#
# Copy to `.env` (same directory as docker-compose.yml) and fill in.
# `docker compose` automatically loads this file.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=10

# Comma-separated list of origins the backend will accept.
# In production, this is your public frontend URL.
CORS_ORIGINS=https://piano.weirdcat.uk

# ── AI mode ──────────────────────────────────────────────────────────────────
# Lyra has two recommendation cycles:
#
#   1. CNN-only   (default when GEMINI_API_KEY is empty)
#                 Pure on-device cycle: deterministic engine + per-user CNN,
#                 ε-greedy blended. No external API calls. No strategy hints.
#
#   2. CNN + LLM  (when GEMINI_API_KEY is set)
#                 Same pipeline, then Gemini reviews the pick and may add a
#                 short strategy hint shown to the student.
#
# Leave GEMINI_API_KEY empty for the CNN-only cycle.
# Set LYRA_USE_LLM=false to force CNN-only even if a key is present.
GEMINI_API_KEY=
LYRA_USE_LLM=

# Frontend build-time envs (baked into the static bundle).
# In a same-origin reverse-proxy setup leave VITE_API_URL=/api.
VITE_API_URL=/api
VITE_ALLOWED_HOSTS=piano.weirdcat.uk

PORT=3000

# SQLite file. Relative paths resolve against the LyraBackend directory.
# Use an absolute path (e.g. /data/database.sqlite) when running in Docker.
DB_PATH=./database.sqlite
DB_TIMEOUT=5000

# REQUIRED — generate a strong secret with: openssl rand -hex 32
# The server refuses to start in production if this is missing or a placeholder.
JWT_SECRET=
JWT_EXPIRES_IN=30d

BCRYPT_SALT_ROUNDS=10

# URL of the LyraAI service (Python/FastAPI)
LYRA_AI_URL=http://localhost:8001

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Set to "production" on the VPS
NODE_ENV=development

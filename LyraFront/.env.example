# Backend API base URL.
# Local dev: http://localhost:3000/api
# Production behind a reverse proxy on the same domain: /api
VITE_API_URL=http://localhost:3000/api

# Comma-separated list of hostnames Vite's dev/preview server will accept
# (in addition to localhost). Required when running behind a public domain.
VITE_ALLOWED_HOSTS=piano.weirdcat.uk
